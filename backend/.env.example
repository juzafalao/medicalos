# ============================================================
# MedicalOS Backend - Environment Variables
# Copie para .env e preencha os valores
# ============================================================

# Aplicação
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Banco de Dados (Supabase)
DB_HOST=db.xxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui
DB_SSL=true

# JWT
JWT_SECRET=seu_jwt_secret_super_seguro_aqui_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=seu_refresh_secret_diferente_aqui_min_32
JWT_REFRESH_EXPIRES_IN=7d

# Redis (para filas WhatsApp)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# WhatsApp - Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WhatsApp - Blip
# Configurado por tenant no banco de dados

# Storage (AWS S3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=sua_access_key
AWS_SECRET_ACCESS_KEY=sua_secret_key
AWS_S3_BUCKET=medicalos-uploads

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@medicalos.com.br
SMTP_PASSWORD=sua_senha_app

# Supabase (opcional para auth via supabase)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGc...
